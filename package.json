{
  "name": "code-cartographer",
  "displayName": "Code Cartographer",
  "description": "Automatically generate comprehensive documentation of your codebase",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-cartographer.generate",
        "title": "Generate Documentation",
        "category": "Code Cartographer",
        "icon": "$(map)"
      },
      {
        "command": "code-cartographer.view",
        "title": "View Documentation",
        "category": "Code Cartographer",
        "icon": "$(preview)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "codeCartographerExplorer",
          "name": "Documentation Explorer"
        }
      ]
    },
    "configuration": {
      "title": "Code Cartographer",
      "properties": {
        "codeCartographer.outputFormat": {
          "type": "string",
          "enum": [
            "json",
            "txt",
            "csv"
          ],
          "default": "json",
          "description": "Output format for documentation"
        },
        "codeCartographer.documentationType": {
          "type": "string",
          "enum": [
            "structure",
            "documentation",
            "both"
          ],
          "default": "both",
          "description": "Type of documentation to generate"
        },
        "codeCartographer.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "out",
            "dist"
          ],
          "description": "Additional patterns to ignore beyond .gitignore"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "code-cartographer.generate",
          "when": "view == codeCartographerExplorer",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "code-cartographer.generate",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.97.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.19.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "micromatch": "^4.0.8"
  }
}
